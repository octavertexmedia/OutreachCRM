# Production bootstrap for /var/www/outreachcrm/.env
# Live site: https://outreach.vertexcrm.in — DNS A → same Contabo VPS as AgencyCRM.
# App secrets (SESSION_SECRET, ENCRYPTION_KEY, OPENAI_*, OAuth, bootstrap admin)
# live in OpenBao at https://secrets.revnext.in/ — see deploy/OPENBAO.md

ADDR=:8080
DATA_DIR=/data
COOKIE_SECURE=true
DRY_RUN_SMTP=true
PUBLIC_BASE_URL=https://outreach.vertexcrm.in
OAUTH_REDIRECT_BASE=https://outreach.vertexcrm.in
APP_VERSION=2.0.0

# --- OpenBao (secrets.revnext.in / ~/revnext-secrets) ---
# Only AppRole bootstrap credentials belong in this file.
OPENBAO_ENABLED=true
OPENBAO_REQUIRED=true
# Prefer http://openbao:8200 after deploy links the secrets container network alias.
OPENBAO_ADDR=http://172.17.0.1:8200
OPENBAO_MOUNT_POINT=secret
OPENBAO_SECRET_PATH=vertexcrm/outreach
OPENBAO_ENVIRONMENT=production
OPENBAO_ROLE_ID=
OPENBAO_SECRET_ID=
# OPENBAO_OVERWRITE_ENV=true
# OPENBAO_TLS_VERIFY=true

# Optional non-secret toggles (may also live in KV)
# DELIVERABILITY_SMTP_VERIFY=false
# DELIVERABILITY_BLACKLIST_CHECK=true
# WORKER_INTERVAL=30s
