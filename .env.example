ADDR=:8080
DATA_DIR=data
PUBLIC_BASE_URL=http://localhost:8080
OAUTH_REDIRECT_BASE=http://localhost:8080
SESSION_SECRET=replace-with-long-random-string
COOKIE_SECURE=false
# Optional HTTPS (terminate here or at reverse proxy)
TLS_CERT_FILE=
TLS_KEY_FILE=

ENCRYPTION_KEY=
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
BOOTSTRAP_ADMIN_PASSWORD=changeme

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

WORKER_INTERVAL=30s
IMAP_INTERVAL=2m
MAX_SEND_ATTEMPTS=5
DRY_RUN_SMTP=true
BACKUP_INTERVAL=24h
PII_RETENTION_DAYS=365

# Email Deliverability Engine
DELIVERABILITY_SMTP_VERIFY=false
DELIVERABILITY_BLACKLIST_CHECK=true
DELIVERABILITY_REQUIRE_AUTH=false
DELIVERABILITY_OPTIMIZE_SEND_TIME=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

APP_VERSION=2.0.0

# --- OpenBao (production: https://secrets.revnext.in/) ---
# Local dev: leave OPENBAO_ENABLED unset/false and use the vars above.
# Production Contabo: see deploy/OPENBAO.md and deploy/.env.example
# OPENBAO_ENABLED=true
# OPENBAO_REQUIRED=true
# OPENBAO_ADDR=https://secrets.revnext.in
# OPENBAO_MOUNT_POINT=secret
# OPENBAO_SECRET_PATH=vertexcrm/outreach
# OPENBAO_ENVIRONMENT=production
# OPENBAO_ROLE_ID=
# OPENBAO_SECRET_ID=
